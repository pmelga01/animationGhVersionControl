# Documentation: https://git-lfs.github.com
# Track all Blender files with LFS
*.blend filter=lfs diff=lfs merge=lfs -text

# Track 3D exports
*.fbx filter=lfs diff=lfs merge=lfs -text
*.obj filter=lfs diff=lfs merge=lfs -text
*.abc filter=lfs diff=lfs merge=lfs -text

# Track Video editing
*.prproj filter=lfs diff=lfs merge=lfs -text
*.aep filter=lfs diff=lfs merge=lfs -text
*.aepx filter=lfs diff=lfs merge=lfs -text
*.drp filter=lfs diff=lfs merge=lfs -text
*.dra filter=lfs diff=lfs merge=lfs -text
*.drt filter=lfs diff=lfs merge=lfs -text

# Ensure scripts and text files stay as text
*.py text
*.txt text
*.md text
*.json text

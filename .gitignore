*.png
*.jpg
*.exr
*.mp4
*.mov

# --- Adobe Premiere Pro ---
# Ignore the entire auto-save folder (keep it local)
Adobe\ Premiere\ Pro\ Auto-Save/
# Ignore preview files and media cache
Adobe\ Premiere\ Pro\ Video\ Previews/
Adobe\ Premiere\ Pro\ Audio\ Previews/
Media\ Cache/

# --- OS Specific ---
.DS_Store
Thumbs.db
